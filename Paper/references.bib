@misc{mlk_permit_denied,
  author       = {{Gun Owners of America}},
  title        = {Martin Luther King Applied to Carry Concealed for Self-Defense But Was Denied},
  year         = {2021},
  url          = {https://www.gunowners.org/mlk-denied-concealed-carry-permit/},
  note         = {Documents the denial of Dr.\ Martin Luther King Jr.'s application for a concealed carry permit in Montgomery, Alabama, in 1956. After his home was bombed and he faced daily death threats, King applied for a permit; local authorities denied it under Alabama's ``may-issue'' discretion. The denial is a canonical example of how discretionary permitting regimes were used to disarm Black Americans seeking self-protection. The denial is confirmed by Robert F. Williams's memoir \textit{Negroes with Guns} (1962) and biographer Taylor Branch.},
}

@online{goa_mlk_harvard,
