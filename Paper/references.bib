  title        = {Racist Gun Laws and the Second Amendment},
  year         = {2022},
  journal      = {Harvard Law Review Forum},
  volume       = {135},
  url          = {https://harvardlawreview.org/forum/vol-135/racist-gun-laws-and-the-second-amendment/},
  note         = {Discusses the historical use of facially neutral gun laws for racial discrimination, specifically citing King's 1956 permit denial as a paradigm case. Analyzes how may-issue discretionary regimes enabled selective disarmament of Black Americans and the implications of \textit{Bruen} (2022) for eliminating this discretion.},
}

