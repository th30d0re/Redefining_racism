\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{usc_macros}[2026/04/16 U.S. Code excerpt helpers (nickvido/us-code)]

\RequirePackage{verbatim}
% Git diffs: keep \verbatiminput (listings breaklines=true can exhaust TeX memory on
% long OLRC lines). Snippet files under usc_snippets/ are pre-wrapped (e.g.\ fold -s -w 88).

% Git tag used when regenerating snippets (see Makefile / tools/usc_extract.py).
\newcommand{\USCTag}{\texttt{annual/2025}}

\newcommand{\USCSourceNote}{%
\textit{Excerpts below are verbatim from the Office of the Law Revision Counsel preliminary United States Code, as packaged in the public-domain snapshot repository} \texttt{nickvido/us-code} \textit{(see that repository's \texttt{README.md} for OLRC release-point tags). The generator tag used for this PDF is} \USCTag\textit{; regenerate with} \texttt{make usc-all}\textit{.}%
}

% Inline / chapter pull-quote: snippets are self-contained historicalsource boxes.
\newcommand{\uscinline}[1]{%
  \par\medskip
  \input{usc_snippets/#1}%
  \par\medskip
}
% Plan-name alias (single argument: snippet stem, e.g.\ \texttt{usc\_18\_922g}).
\let\uscquote\uscinline

% Hyperlinked cross-reference to an appendix label.
\newcommand{\usclink}[2]{\hyperref[#1]{#2}}

% Git unified diff, verbatim from tools/usc_write_diffs.sh output (wrap long lines before commit).
\newcommand{\uscshowdiff}[2]{%
  \begin{tcolorbox}[%
    breakable,%
    enhanced,%
    colback=black!4,%
    colframe=black!55,%
    fonttitle=\bfseries,%
    title={\parbox{0.92\linewidth}{\raggedright\footnotesize #1}},%
    fontupper=\ttfamily\footnotesize,%
  ]%
  \verbatiminput{#2}%
  \end{tcolorbox}%
}
% Plan-name alias (same two arguments: title, path to \texttt{.diff} under \texttt{Paper/}).
\let\uscevolution\uscshowdiff
